#!/bin/bash
# Start Weston on the real display.
#
# Everything here is knowledge that is not discoverable from weston's own help:
#
#   LIBSEAT_BACKEND=builtin  weston 14 will only talk to a seat through libseat,
#                            and there is no seatd daemon on Tunix; the builtin
#                            backend runs the seat server inside weston itself.
#   SEATD_VTBOUND=0          turns off VT binding. Tunix has no virtual
#                            terminals, and without this libseat issues VT
#                            ioctls that cannot be answered.
# Keyboard and mouse come from /dev/input/event0 and event1 through libinput,
# so no --continue-without-input is needed.
#
# Anything after `startx` is passed straight through to weston.
set -e

export XDG_RUNTIME_DIR=${XDG_RUNTIME_DIR:-/tmp}
export LIBSEAT_BACKEND=builtin
export SEATD_VTBOUND=0

# There is no GPU. Left to itself mesa probes for one -- drmGetDevice2 has no
# PCI topology to report, so it warns and then tries kmsro, the driver for a
# display-only device paired with a separate render node, which is not built.
# Saying so up front takes the software path directly.
export GBM_ALWAYS_SOFTWARE=1

# No --no-config: /etc/xdg/weston/weston.ini is what tells weston-terminal --
# including the one the panel launcher starts, which gets no arguments -- to use
# JetBrains Mono.
exec weston --backend=drm "$@"
