#!/bin/bash
case "$1" in
  deconfig)
    ifconfig "$interface" 0.0.0.0
    ;;
  bound|renew)
    ifconfig "$interface" "$ip" ${subnet:+netmask "$subnet"} up
    if [ -n "$router" ]; then
      route del default 2>/dev/null || true
      set -- $router
      route add default gw "$1" dev "$interface"
    fi
    if [ -n "$dns" ]; then
      : > /etc/resolv.conf
      for server in $dns; do echo "nameserver $server" >> /etc/resolv.conf; done
    fi
    ;;
esac
exit 0
