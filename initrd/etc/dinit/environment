# Loaded by dinit (PID 1) at startup; every service inherits these. This is
# the environment the old C init exported before spawning the shell.
PATH=/bin:/usr/bin
HOME=/home/root
SHELL=/bin/bash
USER=root
LOGNAME=root
LANG=C.UTF-8
TERM=tunix-256color
TERMINFO=/usr/share/terminfo
XDG_RUNTIME_DIR=/run/user/0
XDG_CONFIG_HOME=/home/root/.config
XDG_CACHE_HOME=/home/root/.cache
