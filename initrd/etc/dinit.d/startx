# The graphical session: weston on the DRM backend, via /bin/startx (which
# holds all the non-discoverable environment: LIBSEAT_BACKEND, SEATD_VTBOUND,
# GBM_ALWAYS_SOFTWARE). Needs rcS for /run/user/0 and /var/log.
#
# restart = true: if the compositor dies the screen comes back by itself;
# dinit's built-in restart rate limiting stops a crash loop.
type = process
command = /bin/startx
depends-on = rcS
restart = true
logfile = /var/log/startx.log
