[submodule "ports/src/bash"]
	path = ports/src/bash
	url = https://git.savannah.gnu.org/git/bash.git
[submodule "ports/src/busybox"]
	path = ports/src/busybox
	url = https://github.com/mirror/busybox.git
[submodule "ports/src/musl"]
	path = ports/src/musl
	url = https://git.musl-libc.org/git/musl
[submodule "ports/src/tinycc"]
	path = ports/src/tinycc
	url = https://github.com/TinyCC/tinycc.git
	branch = mob
[submodule "ports/src/ncurses"]
	path = ports/src/ncurses
	url = https://github.com/ThomasDickey/ncurses-snapshots.git
[submodule "ports/src/nano"]
	path = ports/src/nano
	url = https://git.savannah.gnu.org/git/nano.git
[submodule "ports/src/zlib"]
	path = ports/src/zlib
	url = https://github.com/madler/zlib.git
[submodule "ports/src/libpng"]
	path = ports/src/libpng
	url = https://github.com/pnggroup/libpng.git
[submodule "ports/src/libjpeg-turbo"]
	path = ports/src/libjpeg-turbo
	url = https://github.com/libjpeg-turbo/libjpeg-turbo.git
[submodule "ports/src/lua"]
	path = ports/src/lua
	url = https://github.com/lua/lua.git
[submodule "ports/src/mbedtls"]
	path = ports/src/mbedtls
	url = https://github.com/Mbed-TLS/mbedtls
	branch = mbedtls-3.6
[submodule "ports/src/tty-clock"]
	path = ports/src/tty-clock
	url = https://github.com/xorg62/tty-clock
[submodule "ports/src/tty-tetris"]
	path = ports/src/tty-tetris
	url = https://github.com/xorg62/tty-tetris
[submodule "ports/src/binutils"]
	path = ports/src/binutils
	url = https://sourceware.org/git/binutils-gdb.git
